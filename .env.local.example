# =====================================================================
# Beispielwerte für die lokale Entwicklung.
# Diese Datei wird ins Git eingecheckt, .env.local NICHT.
#
# So einrichten:
#   cp .env.local.example .env.local
# und dann die echten Werte aus dem Supabase Dashboard eintragen
# (Project Settings > API).
# =====================================================================

# URL deines Supabase Projekts.
NEXT_PUBLIC_SUPABASE_URL=https://deinprojekt.supabase.co

# Öffentlicher anon Key. Darf im Browser stehen, weil unsere RLS
# Policies (siehe supabase/schema.sql) den Schreibzugriff regeln.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
